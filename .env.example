# ==============================================
# VOIMA - Variáveis de Ambiente
# ==============================================
# Copie este arquivo para .env.local e preencha com seus dados do Supabase
# NUNCA commite o .env.local no git

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Essas você encontra em:
# Supabase Dashboard → Settings → API
# - Project URL = NEXT_PUBLIC_SUPABASE_URL
# - anon/public key = NEXT_PUBLIC_SUPABASE_ANON_KEY

# ==============================================
# Anthropic Claude (para IA)
# ==============================================
ANTHROPIC_API_KEY=sua-chave-anthropic

# ==============================================
# Z-API WhatsApp
# ==============================================
Z_API_INSTANCE_ID=sua-instance-id
Z_API_TOKEN=seu-token
Z_API_BASE_URL=https://api.z-api.io

# Encontre essas informações em:
# Z-API Dashboard → Instâncias
# - Instance ID = código da instância
# - Token = token de autenticação
