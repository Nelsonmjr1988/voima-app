# ============================================
# CONFIGURAÇÕES DE EMAIL (SMTP)
# ============================================
# Exemplo usando Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
SMTP_FROM=seu_email@gmail.com

# ============================================
# CONFIGURAÇÕES DE WHATSAPP (EVOLUTION API)
# ============================================
# Se usar Evolution API ou similar
WHATSAPP_API_URL=https://api.evolution.example.com
WHATSAPP_API_TOKEN=seu_token_evolucao
WHATSAPP_INSTANCE_ID=seu_instance_id

# ============================================
# Alternativas:
# ============================================
# Para Gmail: criar App Password em https://myaccount.google.com/apppasswords
# Para Outlook: usar seu email e senha
# Para WhatsApp: Evolution API, Twilio, Baileys, etc.
